# =============================================================================
# Cloud Medical Information System — Environment Variables
# Copy this file to `.env` for local development, or set each variable in
# Render Dashboard → Environment. Do not commit real secrets to Git.
# =============================================================================

# --- Flask / Server ---
FLASK_ENV=production
FLASK_DEBUG=0
SECRET_KEY=replace-with-a-long-random-secret-key
PORT=5000
WEB_CONCURRENCY=2
LOG_LEVEL=info

# --- MongoDB Atlas (required) ---
# Flask extensions use MONGODB_*; pharmacist services also accept MONGO_* aliases.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=cloud_med_project
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=cloud_med_project

# --- Google Cloud Vision (pharmacist OCR + document validation) ---
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_VISION_CREDENTIALS_FILE=google_vision_credentials.json
GOOGLE_APPLICATION_CREDENTIALS=google_vision_credentials.json

# --- Google Drive (doctor PDF upload — optional) ---
GOOGLE_DRIVE_CREDENTIALS_FILE=credentials.json
GOOGLE_DRIVE_TOKEN_FILE=token.json
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id

# --- External APIs ---
TAVILY_API_KEY=tvly-your-api-key

# --- Application branding (optional) ---
MEDICAL_CENTER_NAME=Medical Center
DOCTOR_LICENSE_NUMBER=

# --- OCR microservice (optional legacy) ---
OCR_SERVICE_URL=http://localhost:5001

# --- Upload limits ---
MAX_UPLOAD_SIZE_MB=10

# --- Gunicorn tuning (optional) ---
GUNICORN_TIMEOUT=120
GUNICORN_THREADS=2
GUNICORN_KEEPALIVE=5
GUNICORN_PRELOAD=true
